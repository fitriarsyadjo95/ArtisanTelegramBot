# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ADMIN_CHAT_ID=your-telegram-user-id
ALLOWED_USER_IDS=comma,separated,additional,user,ids

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/blackgrid

# Google Calendar
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# Company Details (for PDF branding)
COMPANY_NAME=Blackgrid
COMPANY_PHONE=01x-xxxxxxx
COMPANY_SSM=xxxxxxxxxxxx
COMPANY_ADDRESS=Your business address

# Bank Details (for invoices)
BANK_NAME=Maybank
BANK_ACCOUNT=1234567890
BANK_HOLDER=Your Name

# Bot Password
BOT_PASSWORD=your-password-here

# Server
PORT=8000
